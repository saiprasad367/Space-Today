# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Direct Postgres connection (pooler port 5432 for asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── NASA ─────────────────────────────────────────────────────────────────────
NASA_API_KEY=DEMO_KEY

# ─── Redis ────────────────────────────────────────────────────────────────────
# Leave empty to use in-memory cache (development)
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
